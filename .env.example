# Copy this file to .env and update values for your team.

POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_password
POSTGRES_PORT=5432

RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

ORDER_EXCHANGE=orders.exchange
ORDER_QUEUE=orders.created.queue
ORDER_ROUTING_KEY=orders.created

# Replace these with your real Docker Hub image names for final submission.
PRODUCT_SERVICE_IMAGE=your-dockerhub-username/product-service:latest
ORDER_SERVICE_IMAGE=your-dockerhub-username/order-service:latest
NOTIFICATION_SERVICE_IMAGE=your-dockerhub-username/notification-service:latest

PRODUCT_SERVICE_PORT=8081
ORDER_SERVICE_PORT=8082

